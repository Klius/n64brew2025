func store_buy_upgrade_fast_travel()
    world_pause;

    if upgrade_fast_travel then
        say "Sold out";
        world_unpause;
        return;
    end

    world_pause;
    interact_with_npc INTERACTION_LOOK, ENTITY_ID_PLAYER, store_bot;
    interact_with_npc INTERACTION_LOOK, store_bot, ENTITY_ID_PLAYER;
    cam_look_npc store_bot;
    show_nuts;

    npc_animate store_bot, "bot_talk", true;
    say "
        This upgrade will teleport to take you to places you have been using the D-pad.
    ";

    ask "Do you wish to buy it for {fast_travel_cost} nuts?";

    if ask_response() then
        if nut_count >= fast_travel_cost then
            despawn upgrade_fast_travel_item;
            upgrade_fast_travel = true;
            has_bike_teleport = false;
            nut_count = nut_count - fast_travel_cost;
            say "Good doing business with you";
        else
            say "You don't have enough nuts";
        end
    end

    npc_animate store_bot, "idle", true;

    cam_return;
    world_unpause;
end